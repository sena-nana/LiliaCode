{
  "name": "lilia-workspace",
  "private": true,
  "version": "1.0.0-beta",
  "workspaces": [
    "apps/desktop",
    "packages/*"
  ],
  "scripts": {
    "check:package-manager": "node scripts/check-package-manager.mjs",
    "preinstall": "node scripts/check-package-manager.mjs",
    "pretauri": "node scripts/check-package-manager.mjs",
    "tauri": "yarn check:package-manager && yarn --cwd apps/desktop tauri",
    "pretauri:dev": "node scripts/check-package-manager.mjs",
    "tauri:dev": "yarn check:package-manager && node scripts/tauri-dev.mjs",
    "pretauri:build": "node scripts/check-package-manager.mjs",
    "tauri:build": "yarn check:package-manager && yarn --cwd apps/desktop tauri build",
    "tauri:install": "yarn check:package-manager && yarn tauri:build && node scripts/tauri-install.mjs",
    "predev": "node scripts/check-package-manager.mjs",
    "dev": "yarn check:package-manager && yarn --cwd apps/desktop dev",
    "predocs:dev": "node scripts/check-package-manager.mjs",
    "docs:dev": "yarn check:package-manager && vitepress dev docs",
    "predocs:build": "node scripts/check-package-manager.mjs",
    "docs:build": "yarn check:package-manager && vitepress build docs",
    "predocs:preview": "node scripts/check-package-manager.mjs",
    "docs:preview": "yarn check:package-manager && vitepress preview docs",
    "release:check": "yarn check:package-manager && node scripts/verify-release.mjs",
    "release:smoke:windows": "yarn check:package-manager && node scripts/windows-installer-smoke.mjs",
    "icons:generate": "yarn check:package-manager && node scripts/generate-icons.mjs",
    "icons:tauri": "yarn check:package-manager && node scripts/generate-icons.mjs",
    "android:doctor": "yarn check:package-manager && node scripts/android-doctor.mjs",
    "android:iroh": "powershell -ExecutionPolicy Bypass -File scripts/build-iroh-android.ps1",
    "android:test": "yarn check:package-manager && apps/android/gradlew.bat --no-daemon -p apps/android :app:testDebugUnitTest",
    "android:build": "yarn check:package-manager && apps/android/gradlew.bat --no-daemon -p apps/android :app:assembleDebug",
    "android:build:release": "yarn check:package-manager && apps/android/gradlew.bat --no-daemon -p apps/android :app:assembleRelease",
    "android:apk:inspect": "yarn check:package-manager && node scripts/android-apk-inspect.mjs",
    "android:install": "yarn check:package-manager && apps/android/gradlew.bat --no-daemon -p apps/android :app:installDebug",
    "android:smoke": "yarn check:package-manager && node scripts/android-smoke.mjs",
    "android:smoke:pairing": "yarn check:package-manager && node scripts/android-smoke.mjs --require-pairing",
    "android:smoke:test": "yarn check:package-manager && node scripts/android-smoke-lib.test.mjs",
    "android:verify": "yarn android:doctor && yarn android:smoke:test && yarn android:test && yarn android:build && yarn android:build:release && yarn android:apk:inspect",
    "prebuild": "node scripts/check-package-manager.mjs",
    "build": "yarn check:package-manager && yarn --cwd apps/desktop build",
    "pretest": "node scripts/check-package-manager.mjs",
    "test": "yarn check:package-manager && yarn --cwd apps/desktop test",
    "preverify": "node scripts/check-package-manager.mjs",
    "verify": "yarn check:package-manager && yarn verify:desktop:test && yarn verify:desktop:build && yarn verify:tauri && yarn verify:contracts",
    "preverify:desktop:test": "node scripts/check-package-manager.mjs",
    "verify:desktop:test": "yarn check:package-manager && yarn --cwd apps/desktop test",
    "preverify:desktop:build": "node scripts/check-package-manager.mjs",
    "verify:desktop:build": "yarn check:package-manager && yarn --cwd apps/desktop build",
    "preverify:tauri": "node scripts/check-package-manager.mjs",
    "verify:tauri": "yarn check:package-manager && cargo check --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "preverify:contracts": "node scripts/check-package-manager.mjs",
    "verify:contracts": "yarn check:package-manager && node node_modules/typescript/bin/tsc -p packages/contracts/tsconfig.json",
    "verify:agent-debug": "yarn check:package-manager && node apps/desktop/agent-debug/verify-agent-debug.mjs"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  },
  "packageManager": "yarn@4.14.1"
}
