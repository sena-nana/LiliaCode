{
  "name": "lilia-workspace",
  "private": true,
  "version": "1.0.0-beta.1",
  "type": "module",
  "workspaces": [
    "apps/desktop",
    "packages/*"
  ],
  "engines": {
    "node": ">=26.0.0 <27"
  },
  "scripts": {
    "check:toolchain": "node scripts/check-toolchain.ts",
    "preinstall": "node scripts/check-toolchain.ts",
    "pretauri": "node scripts/check-toolchain.ts",
    "tauri": "yarn check:toolchain && yarn --cwd apps/desktop tauri",
    "pretauri:dev": "node scripts/check-toolchain.ts",
    "tauri:dev": "yarn check:toolchain && node scripts/tauri-dev.mjs",
    "pretauri:build": "node scripts/check-toolchain.ts",
    "tauri:build": "yarn check:toolchain && node scripts/with-rust-cache.mjs yarn --cwd apps/desktop tauri build",
    "tauri:build:no-bundle": "yarn check:toolchain && node scripts/with-rust-cache.mjs yarn --cwd apps/desktop tauri build --no-bundle",
    "tauri:install": "yarn check:toolchain && node scripts/tauri-install.mjs",
    "liliaui:local": "yarn check:toolchain && node scripts/lilia-ui-deps.mjs local",
    "liliaui:remote": "yarn check:toolchain && node scripts/lilia-ui-deps.mjs remote",
    "liliaui:status": "yarn check:toolchain && node scripts/lilia-ui-deps.mjs status",
    "predev": "node scripts/check-toolchain.ts",
    "dev": "yarn check:toolchain && yarn --cwd apps/desktop dev",
    "predocs:dev": "node scripts/check-toolchain.ts",
    "docs:dev": "yarn check:toolchain && vitepress dev docs",
    "predocs:build": "node scripts/check-toolchain.ts",
    "docs:build": "yarn check:toolchain && vitepress build docs",
    "predocs:preview": "node scripts/check-toolchain.ts",
    "docs:preview": "yarn check:toolchain && vitepress preview docs",
    "release:check": "yarn check:toolchain && node scripts/verify-release.mjs",
    "release:smoke:windows": "yarn check:toolchain && node scripts/windows-installer-smoke.mjs",
    "icons:generate": "yarn check:toolchain && node scripts/generate-icons.mjs",
    "icons:tauri": "yarn check:toolchain && node scripts/generate-icons.mjs",
    "android:doctor": "yarn check:toolchain && node scripts/android-doctor.mjs",
    "android:iroh": "powershell -ExecutionPolicy Bypass -File scripts/build-iroh-android.ps1",
    "android:test": "yarn check:toolchain && apps/android/gradlew.bat --no-daemon -p apps/android :app:testDebugUnitTest",
    "android:build": "yarn check:toolchain && apps/android/gradlew.bat --no-daemon -p apps/android :app:assembleDebug",
    "android:build:release": "yarn check:toolchain && apps/android/gradlew.bat --no-daemon -p apps/android :app:assembleRelease",
    "android:apk:inspect": "yarn check:toolchain && node scripts/android-apk-inspect.mjs",
    "android:install": "yarn check:toolchain && apps/android/gradlew.bat --no-daemon -p apps/android :app:installDebug",
    "android:smoke": "yarn check:toolchain && node scripts/android-smoke.mjs",
    "android:smoke:pairing": "yarn check:toolchain && node scripts/android-smoke.mjs --require-pairing",
    "android:smoke:test": "yarn check:toolchain && node scripts/android-smoke-lib.test.mjs",
    "android:verify": "yarn android:doctor && yarn android:smoke:test && yarn android:test && yarn android:build && yarn android:build:release && yarn android:apk:inspect",
    "prebuild": "node scripts/check-toolchain.ts",
    "build": "yarn check:toolchain && yarn --cwd apps/desktop build",
    "bundle:desktop:report": "yarn check:toolchain && node scripts/report-desktop-bundle.mjs",
    "bundle:desktop:check": "yarn check:toolchain && node scripts/report-desktop-bundle.mjs --check",
    "pretest": "node scripts/check-toolchain.ts",
    "test": "yarn check:toolchain && yarn --cwd apps/desktop test",
    "typecheck:node-scripts": "node node_modules/typescript/bin/tsc -p tsconfig.node-scripts.json",
    "preverify": "node scripts/check-toolchain.ts",
    "verify": "yarn check:toolchain && yarn typecheck:node-scripts && yarn verify:desktop:test && yarn verify:desktop:build && yarn verify:tauri && yarn verify:contracts",
    "preverify:desktop:test": "node scripts/check-toolchain.ts",
    "verify:desktop:test": "yarn check:toolchain && yarn --cwd apps/desktop test",
    "preverify:desktop:build": "node scripts/check-toolchain.ts",
    "verify:desktop:build": "yarn check:toolchain && yarn --cwd apps/desktop build && yarn bundle:desktop:check",
    "preverify:tauri": "node scripts/check-toolchain.ts",
    "verify:tauri": "yarn check:toolchain && node scripts/with-rust-cache.mjs cargo check --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "preverify:contracts": "node scripts/check-toolchain.ts",
    "verify:contracts": "yarn check:toolchain && node node_modules/typescript/bin/tsc -p packages/contracts/tsconfig.json",
    "verify:agent-debug": "yarn check:toolchain && node scripts/with-rust-cache.mjs node apps/desktop/agent-debug/verify-agent-debug.mjs"
  },
  "devDependencies": {
    "@lilia/build": "github:sena-nana/LiliaUI#workspace=@lilia/build&commit=ae25c7b8ef6c6a9e38b6b64779d4ff085aa584bf",
    "@lilia/config": "github:sena-nana/LiliaUI#workspace=@lilia/config&commit=ae25c7b8ef6c6a9e38b6b64779d4ff085aa584bf",
    "@lilia/tools": "github:sena-nana/LiliaUI#workspace=@lilia/tools&commit=ae25c7b8ef6c6a9e38b6b64779d4ff085aa584bf",
    "@types/node": "^26.1.1",
    "vitepress": "^1.6.4"
  },
  "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697"
}
