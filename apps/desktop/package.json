{
  "name": "desktop",
  "private": true,
  "version": "1.0.0-beta.1",
  "type": "module",
  "scripts": {
    "about:licenses": "yarn --cwd ../.. lilia-tools licenses --project-root apps/desktop --unknown-license 未声明",
    "check:package-manager": "node ../../scripts/check-package-manager.mjs",
    "prebuild": "yarn about:licenses",
    "dev": "node ../../scripts/check-package-manager.mjs && lilia-build dev",
    "build": "node ../../scripts/check-package-manager.mjs && lilia-build build",
    "test": "node ../../scripts/check-package-manager.mjs && lilia-build test --fileParallelism=false",
    "preview": "node ../../scripts/check-package-manager.mjs && lilia-build preview",
    "tauri": "node ../../scripts/check-package-manager.mjs && lilia-build tauri",
    "tauri:dev": "yarn --cwd ../.. tauri:dev",
    "tauri:build": "yarn --cwd ../.. tauri:build",
    "tauri:build:no-bundle": "yarn --cwd ../.. tauri:build:no-bundle",
    "tauri:install": "yarn --cwd ../.. tauri:install"
  },
  "devDependencies": {
    "@lilia/build": "github:sena-nana/LiliaUI#workspace=@lilia/build&commit=ed10f51023c321c1bbec799979e1047f91eb9f2f",
    "@lilia/config": "github:sena-nana/LiliaUI#workspace=@lilia/config&commit=ed10f51023c321c1bbec799979e1047f91eb9f2f",
    "@lilia/tools": "github:sena-nana/LiliaUI#workspace=@lilia/tools&commit=ed10f51023c321c1bbec799979e1047f91eb9f2f"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.195",
    "@anthropic-ai/sdk": "^0.106.0",
    "@lilia/contracts": "workspace:*",
    "@lilia/ui": "github:sena-nana/LiliaUI#workspace=@lilia/ui&commit=ed10f51023c321c1bbec799979e1047f91eb9f2f",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@vue-flow/core": "^1.48.2",
    "chart.js": "^4.5.1",
    "katex": "^0.17.0",
    "mermaid": "^11.16.0",
    "qrcode": "^1.5.4",
    "zod": "^4.4.3"
  }
}
