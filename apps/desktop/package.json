{
  "name": "desktop",
  "private": true,
  "version": "1.0.0-beta.1",
  "type": "module",
  "scripts": {
    "about:licenses": "node scripts/generate-open-source-license-manifest.mjs",
    "check:package-manager": "node ../../scripts/check-package-manager.mjs",
    "prebuild": "yarn about:licenses",
    "dev": "node ../../scripts/check-package-manager.mjs && vite",
    "build": "node ../../scripts/check-package-manager.mjs && vue-tsc --noEmit && vite build",
    "test": "node ../../scripts/check-package-manager.mjs && vitest run",
    "preview": "node ../../scripts/check-package-manager.mjs && vite preview",
    "tauri": "node ../../scripts/check-package-manager.mjs && tauri",
    "tauri:dev": "yarn --cwd ../.. tauri:dev",
    "tauri:build": "yarn --cwd ../.. tauri:build",
    "tauri:build:no-bundle": "yarn --cwd ../.. tauri:build:no-bundle",
    "tauri:install": "yarn --cwd ../.. tauri:install"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.195",
    "@anthropic-ai/sdk": "^0.106.0",
    "@lilia/contracts": "workspace:*",
    "@lilia/ui": "portal:../../../LiliaUI/packages/ui",
    "@lucide/vue": "^1.21.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@vue-flow/core": "^1.48.2",
    "chart.js": "^4.5.1",
    "katex": "^0.17.0",
    "mermaid": "^11.16.0",
    "qrcode": "^1.5.4",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.39",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
