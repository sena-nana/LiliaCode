{
  "name": "desktop",
  "private": true,
  "version": "1.0.0-beta.1",
  "engines": {
    "node": ">=26.0.0 <27"
  },
  "type": "module",
  "scripts": {
    "about:licenses": "yarn --cwd ../.. lilia-tools licenses --project-root apps/desktop --unknown-license 未声明",
    "check:toolchain": "node ../../scripts/check-toolchain.ts",
    "prebuild": "yarn about:licenses",
    "dev": "node ../../scripts/check-toolchain.ts && lilia-build dev",
    "build": "node ../../scripts/check-toolchain.ts && lilia-build build",
    "test": "node ../../scripts/check-toolchain.ts && lilia-build test --fileParallelism=false",
    "preview": "node ../../scripts/check-toolchain.ts && lilia-build preview",
    "tauri": "node ../../scripts/check-toolchain.ts && lilia-build tauri",
    "tauri:dev": "yarn --cwd ../.. tauri:dev",
    "tauri:build": "yarn --cwd ../.. tauri:build",
    "tauri:build:no-bundle": "yarn --cwd ../.. tauri:build:no-bundle",
    "tauri:install": "yarn --cwd ../.. tauri:install"
  },
  "devDependencies": {
    "@lilia/build": "github:sena-nana/LiliaUI#workspace=@lilia/build&commit=ae25c7b8ef6c6a9e38b6b64779d4ff085aa584bf",
    "@lilia/config": "github:sena-nana/LiliaUI#workspace=@lilia/config&commit=ae25c7b8ef6c6a9e38b6b64779d4ff085aa584bf",
    "@lilia/tools": "github:sena-nana/LiliaUI#workspace=@lilia/tools&commit=ae25c7b8ef6c6a9e38b6b64779d4ff085aa584bf"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.195",
    "@anthropic-ai/sdk": "^0.106.0",
    "@lilia/contracts": "workspace:*",
    "@lilia/ui": "github:sena-nana/LiliaUI#workspace=@lilia/ui&commit=ae25c7b8ef6c6a9e38b6b64779d4ff085aa584bf",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@vue-flow/core": "^1.48.2",
    "chart.js": "^4.5.1",
    "katex": "^0.17.0",
    "mermaid": "^11.16.0",
    "qrcode": "^1.5.4",
    "zod": "^4.4.3"
  },
  "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697"
}
