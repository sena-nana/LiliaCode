{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LiliaCode",
  "version": "0.1.0-alpha.1",
  "identifier": "com.lilia.desktop",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LiliaCode",
        "width": 960,
        "height": 600,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "backgroundColor": "#181818",
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.lilia/cache/clipboard-images/**",
          "$HOME/.lilia/cache/iab-snapshots/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
