# =============================================================================
# Lilia · root .gitignore
# =============================================================================

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ---------- 编辑器 / IDE ----------
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.vs/
*.swp
*.swo
*~
*.bak

# ---------- 日志 ----------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- 环境变量 / 机密 ----------
.env
.env.*
!.env.example
*.pem
*.key
.secrets/

# ---------- Node.js / 前端 ----------
node_modules/
**/node_modules/
.npm/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*
.cache/
.vite/
dist/
**/dist/
*.local

# ---------- Android / Gradle ----------
.gradle/
**/.gradle/
**/build/
**/local.properties
captures/

# ---------- TypeScript ----------
*.tsbuildinfo
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map

# ---------- 测试 / 覆盖率 ----------
coverage/
*.lcov
.vitest-cache/
agent-debug-runs/

# ---------- Rust / Cargo / Tauri ----------
target/
**/target/
**/*.rs.bk
*.pdb
**/src-tauri/gen/schemas/

# ---------- 数据库 ----------
*.sqlite
*.sqlite3
*.db

# ---------- AI / Agent 副产物 ----------
.claude/
.claude-flow/
.mcp.json
CLAUDE.md

# ---------- 临时 ----------
tmp/
temp/
*.tmp
*.pid
